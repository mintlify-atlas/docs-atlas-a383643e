  "keyFeatures": [
    "Decentralized P2P graph database with real-time sync",
    "Advanced graph traversal with recursive $edge operator",
    "WebAuthn authentication and RBAC security model",
    "Offline-first with OPFS storage and cross-tab sync",
    "Cellular mesh topology for massive scalability",
    "Hybrid delta protocol with full-state fallback",
    "Modular architecture with optional extensions (Geo, NLQ, Radix Tree, ACLs)"
  ],
  "publicApiSurface": [
    "gdb(name, options)",
    "db.put(value, id?)",
    "db.get(id, callback?)",
    "db.map(...args)",
    "db.link(sourceId, targetId)",
    "db.remove(id)",
    "db.clear()",
    "db.sm (Security Manager module)",
    "db.rtc (GenosRTC P2P module)",
    "db.rx (Radix Tree module)",
    "db.geo (Geo Query module)",
    "db.nlq (Natural Language Query module)",
    "db.audit (Audit module)",
    "$edge (recursive graph traversal)",
    "$text (full-text search)",
    "$eq, $ne, $gt, $gte, $lt, $lte (comparison operators)",
    "$in, $between, $exists (query operators)",
    "$and, $or, $not (logical operators)",
    "$like, $regex (pattern matching)",
    "$near, $bbox (geo queries)"
  ]
